{
  "name": "workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3103",
    "build": "next build",
    "start": "next start -p 3103",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:start": "tsx scripts/db-start.ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-scale": "tsx scripts/seed-scale.ts",
    "migration:guard": "prisma migrate diff --from-migrations prisma/migrations --to-schema-datamodel prisma/schema.prisma --shadow-database-url postgresql://duel:duel@127.0.0.1:4103/shadow --exit-code",
    "test": "tsx --test tests/*.test.ts",
    "smoke:concurrency": "tsx scripts/concurrency-smoke.ts",
    "ci": "npm run lint && npm run typecheck && npm run migration:guard && npm run test"
  },
  "dependencies": {
    "@clerk/nextjs": "7.5.20",
    "@prisma/client": "6.19.3",
    "@vercel/blob": "2.6.1",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "embedded-postgres": "18.4.0-beta.17",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prisma": "6.19.3",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}

