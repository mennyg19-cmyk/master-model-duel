{
  "name": "tomchei-arm-03",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3103",
    "build": "next build",
    "start": "next start --port 3103",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:start": "node scripts/start-db.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node --env-file=.env --import tsx scripts/seed.ts",
    "db:generate": "prisma generate",
    "test:permissions": "node --import tsx scripts/permissions.test.ts",
    "test:concurrency": "node --env-file=.env --import tsx scripts/concurrency-smoke.ts",
    "test:domain-p2": "node --env-file=.env --import tsx scripts/domain-p2.test.ts",
    "ci:migrate-guard": "node scripts/migrate-guard.mjs",
    "ci": "npm run lint && npm run typecheck && npm run ci:migrate-guard && npm run test:permissions && npm run test:domain-p2",
    "smoke": "node --env-file=.env scripts/smoke.mjs",
    "smoke:p3": "node --env-file=.env scripts/smoke-p3.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "6.12.0",
    "@prisma/client": "6.5.0",
    "clsx": "2.1.1",
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "3.0.2",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@types/node": "20.17.19",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "embedded-postgres": "18.4.0-beta.17",
    "eslint": "9.20.1",
    "eslint-config-next": "15.1.0",
    "postcss": "8.5.2",
    "prisma": "6.5.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.3",
    "typescript": "5.7.3"
  }
}
