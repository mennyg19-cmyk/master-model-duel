# Arm-03 ports: web 3103, db 4103
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:4103/tomchei?schema=public
WEB_PORT=3103

# Default (when unset) is clerk — fail closed without keys.
# Local smoke must opt in explicitly:
AUTH_MODE=dev

# Required when AUTH_MODE=clerk (or when AUTH_MODE is unset)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Required when AUTH_MODE=dev
DEV_MANAGER_USER_ID=dev_manager_1
DEV_STAFF_USER_ID=dev_staff_1
DEV_DRIVER_USER_ID=dev_driver_1
DEV_CUSTOMER_USER_ID=dev_customer_1

# Optional: force a specific signed-in identity in AUTH_MODE=dev via cookie/header
# DEV_ACTING_USER_ID=

APP_URL=http://127.0.0.1:3103
NODE_ENV=development

# Required for newsletter HMAC (fail-closed; no public fallback)
NEWSLETTER_HMAC_SECRET=tomchei-arm03-newsletter-hmac-dev-only

# Guest draft access tokens (falls back to NEWSLETTER_HMAC_SECRET if unset)
DRAFT_ACCESS_SECRET=tomchei-arm03-draft-access-hmac-dev-only

# Stripe — use STRIPE_MODE=mock for local smoke
STRIPE_MODE=mock
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_mock_dev_only
