# Postgres connection (embedded dev DB runs on port 4103 via `npm run db:start`)
DATABASE_URL=postgresql://duel:duel@127.0.0.1:4103/tomchei

# "dev" = local email/password staff auth. "clerk" = Clerk-hosted auth (requires the two keys below).
AUTH_MODE=dev

# Signs staff session tokens. Any random string of 16+ characters.
# This placeholder is REFUSED in real mode (production, or live Stripe/Shippo
# credentials set) â€” generate your own, e.g. `openssl rand -hex 32`.
SESSION_SECRET=change-me-to-a-random-string

# REQUIRED "true" in production (startup fails without it): rate limiting
# keys on the client IP your proxy appends to X-Forwarded-For. Vercel and any
# reverse-proxy deployment qualify. Leave empty ONLY for direct-served dev â€”
# there the header is client-forgeable and everyone shares one bucket.
TRUST_PROXY=

# Required only when AUTH_MODE=clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe. Leave STRIPE_SECRET_KEY empty to run the built-in mock gateway
# (local hosted-checkout page + signed webhooks through the real route).
# The mock gateway is DEV-ONLY: production startup fails without a secret key.
STRIPE_SECRET_KEY=
# Real mode (secret key set) REQUIRES your endpoint secret from the Stripe
# dashboard here â€” startup fails closed if this is still the public dev default.
STRIPE_WEBHOOK_SECRET=whsec_dev_mock_secret

# Absolute base URL used for Stripe success/cancel redirects.
APP_URL=http://127.0.0.1:3103

# Shippo. Leave SHIPPO_API_TOKEN empty for mock mode (deterministic fixture
# rates â€” same idea as the Stripe mock). Live mode requires ALL THREE: the
# token plus the org's negotiated FedEx and UPS carrier-account ids in Shippo.
SHIPPO_API_TOKEN=
SHIPPO_FEDEX_ACCOUNT_ID=
SHIPPO_UPS_ACCOUNT_ID=
# Optional: when set, live rate quoting includes USPS alongside FedEx/UPS.
SHIPPO_USPS_ACCOUNT_ID=

# Bearer secret protecting /api/cron/* (pickup expiry, payment reminders).
# 16+ characters. Leave unset to disable cron endpoints entirely (they 503).
CRON_SECRET=

# Mapbox geocoding for delivery routes. Leave empty to use the built-in
# deterministic local geocoder (dev-only stand-in, same idea as the mocks above).
MAPBOX_ACCESS_TOKEN=

# Resend email delivery. Leave empty for the mock provider (simulated
# delivery, dev-only). Production requires a key OR explicit EMAIL_TEST_MODE.
RESEND_API_KEY=

# "true" = capture every outgoing email/SMS in the outbox instead of
# contacting any provider â€” even with live keys set. The safe testing switch.
EMAIL_TEST_MODE=

# "true" forces test mode (banner + test console) even with live keys set.
# Test mode is otherwise inferred from mock money (no STRIPE_SECRET_KEY).
TEST_MODE=

# Twilio-class SMS (all three required together for live mode; empty = mock).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

