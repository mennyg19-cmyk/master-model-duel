generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  MANAGER
  STAFF
  DRIVER
}

enum StaffStatus {
  INVITED
  ACTIVE
  REVOKED
}

enum SeasonStatus {
  OPEN
  CLOSED
}

enum ProductKind {
  PACKAGE
  ADD_ON
  DONATION
}

enum OrderStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum RecipientAssignmentSource {
  ON_ORDER
  ADDRESS_BOOK
  NEW_RECIPIENT
}

enum CachedPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum PackageStage {
  NEW
  PRINTED
  PACKED
  SENT
  PICKED_UP
}

enum PrintBatchKind {
  NIGHTLY
  REPRINT_GROUP
  REPRINT_ORDER
}

enum PrintArtifactKind {
  SLIPS
  LABELS
  GREETING_CARDS
  PACKING_SLIP
}

enum ShippingLabelStatus {
  PURCHASED
  VOIDED
  FAILED
}

enum DeliveryRouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum DeliveryStopStatus {
  PENDING
  DELIVERED
}

enum MessageChannel {
  EMAIL
  SMS
}

enum MessageStatus {
  PENDING
  PROCESSING
  SENT
  CAPTURED
  FAILED
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
}

enum PaymentMethod {
  STRIPE
  CASH
  CHECK
  COMP
}

enum PaymentStatus {
  POSTED
  VOIDED
}

enum PaymentIntentStatus {
  CREATED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum InventoryTargetKind {
  PRODUCT
  ADD_ON
}

enum AssemblyBatchStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model StaffUser {
  id               String         @id @default(cuid())
  clerkUserId      String?        @unique
  email            String         @unique
  displayName      String
  role             StaffRole
  status           StaffStatus    @default(INVITED)
  grantPermissions String[]       @default([])
  denyPermissions  String[]       @default([])
  version          Int            @default(1)
  confirmedAt      DateTime?
  revokedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  invitations      StaffInvite[]
  sessions         SessionStamp[]
  assignedRoutes   DeliveryRoute[] @relation("AssignedDriver")

  @@index([status, role])
}

model CustomerAccount {
  id          String    @id @default(cuid())
  clerkUserId String    @unique
  email       String
  customerId  String?   @unique
  customer    Customer? @relation(fields: [customerId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model StaffInvite {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  email       String
  role        StaffRole
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  invitedBy   StaffUser @relation(fields: [invitedById], references: [id])
  createdAt   DateTime  @default(now())
}

model BootstrapState {
  key            String   @id
  managerStaffId String
  managerClerkId String   @unique
  completedAt    DateTime @default(now())
}

model AppSetting {
  key       String   @id
  value     Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id             String   @id @default(cuid())
  actorStaffId   String?
  action         String
  targetType     String
  targetId       String
  metadata       Json?
  occurredAt     DateTime @default(now())
  requestId      String?
  impersonatorId String?

  @@index([targetType, targetId, occurredAt])
  @@index([actorStaffId, occurredAt])
}

model ImportBatch {
  id             String    @id @default(cuid())
  entityType     String
  status         String    @default("STAGED")
  sourceName     String
  rows           Json
  errors         Json
  validRowCount  Int
  invalidRowCount Int
  duplicateCount Int
  stagedByStaffId String
  committedByStaffId String?
  committedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([entityType, createdAt])
  @@index([status, createdAt])
}

model ImpersonationSession {
  id            String    @id @default(cuid())
  actorStaffId  String
  targetStaffId String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
}

model SessionStamp {
  id             String    @id @default(cuid())
  staffUserId    String
  staffUser      StaffUser @relation(fields: [staffUserId], references: [id])
  clerkSessionId String    @unique
  lastSeenAt     DateTime  @default(now())
  ipHash         String?

  @@index([staffUserId, lastSeenAt])
}

model Season {
  id                 String              @id @default(cuid())
  name               String
  year               Int                 @unique
  status             SeasonStatus        @default(CLOSED)
  scheduledStatus    SeasonStatus?
  scheduledStatusAt  DateTime?
  nextOrderNumber    Int                 @default(1)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  products           Product[]
  orders             Order[]
  fulfillmentMethods FulfillmentMethod[]
  pickupLocations    PickupLocation[]
  packageTypes       PackageType[]
  assemblyBatches    AssemblyBatch[]

  @@index([status, scheduledStatusAt])
}

model Product {
  id                   String                @id @default(cuid())
  seasonId             String
  season               Season                @relation(fields: [seasonId], references: [id])
  sku                  String
  name                 String
  description          String?
  category             String                @default("Gifts")
  imageUrl             String?
  kind                 ProductKind
  priceCents           Int
  widthMm              Int?
  heightMm             Int?
  depthMm              Int?
  weightGrams          Int?
  tracksInventory      Boolean               @default(true)
  isFinishedPackage    Boolean               @default(false)
  isActive             Boolean               @default(true)
  replacementProductId String?
  replacementProduct   Product?              @relation("ProductReplacement", fields: [replacementProductId], references: [id])
  replacedProducts     Product[]             @relation("ProductReplacement")
  version              Int                   @default(1)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  options              ProductOption[]
  allowedAddOns        ProductAllowedAddOn[] @relation("BaseProductAddOns")
  allowedForProducts   ProductAllowedAddOn[] @relation("AllowedAddOn")
  orderLines           OrderLine[]
  inventoryItem        InventoryItem?        @relation("ProductInventory")
  addOnInventoryItem   InventoryItem?        @relation("AddOnInventory")
  orderLineAddOns      OrderLineAddOn[]
  ingredients          ProductIngredient[]

  @@unique([seasonId, sku])
  @@index([seasonId, kind, isActive])
}

model NewsletterSubscriber {
  id                 String   @id @default(cuid())
  email              String   @unique
  productUpdates     Boolean  @default(true)
  volunteerStories   Boolean  @default(true)
  communityImpact    Boolean  @default(true)
  isSubscribed       Boolean  @default(true)
  subscribedAt       DateTime @default(now())
  unsubscribedAt     DateTime?
  updatedAt          DateTime @updatedAt
}

model EmailList {
  id              String   @id @default(cuid())
  key             String   @unique
  name            String
  preferenceField String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  campaigns       EmailCampaign[]
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  subject   String
  htmlBody  String
  textBody  String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailCampaign {
  id            String         @id @default(cuid())
  name          String
  subject       String
  htmlBody      String
  textBody      String
  emailListId   String
  emailList     EmailList      @relation(fields: [emailListId], references: [id])
  status        CampaignStatus @default(DRAFT)
  createdById   String
  testSentAt    DateTime?
  sentAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  outboxMessages MessageOutbox[]

  @@index([status, createdAt])
}

model MessageOutbox {
  id                String         @id @default(cuid())
  idempotencyKey    String         @unique
  channel           MessageChannel
  eventKey          String
  templateKey       String?
  recipient         String
  subject           String?
  htmlBody          String?
  textBody          String
  payload           Json
  customerId        String?
  orderId           String?
  packageId         String?
  campaignId        String?
  campaign          EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  status            MessageStatus  @default(PENDING)
  attempts          Int            @default(0)
  nextAttemptAt     DateTime       @default(now())
  lockedAt          DateTime?
  lockedUntil       DateTime?
  lockedBy          String?
  providerMessageId String?
  lastError         String?
  sentAt            DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  attemptLog        MessageAttempt[]

  @@index([status, nextAttemptAt])
  @@index([status, lockedUntil])
  @@index([campaignId, status])
  @@index([customerId, createdAt])
  @@index([orderId, createdAt])
}

model MessageAttempt {
  id                String        @id @default(cuid())
  outboxId          String
  outbox             MessageOutbox @relation(fields: [outboxId], references: [id], onDelete: Cascade)
  attemptNumber     Int
  status            MessageStatus
  providerMessageId String?
  errorMessage      String?
  attemptedAt       DateTime      @default(now())

  @@unique([outboxId, attemptNumber])
  @@index([status, attemptedAt])
}

model MediaAsset {
  id          String   @id @default(cuid())
  pathname    String   @unique
  url         String
  contentType String
  sizeBytes   Int
  uploadedBy  String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model ProductOption {
  id                   String      @id @default(cuid())
  productId            String
  product              Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name                 String
  value                String
  priceAdjustmentCents Int         @default(0)
  isDefault            Boolean     @default(false)
  isActive             Boolean     @default(true)
  orderLines           OrderLine[]

  @@unique([productId, name, value])
}

model ProductAllowedAddOn {
  productId String
  addOnId   String
  product   Product @relation("BaseProductAddOns", fields: [productId], references: [id], onDelete: Cascade)
  addOn     Product @relation("AllowedAddOn", fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([productId, addOnId])
}

model Customer {
  id              String            @id @default(cuid())
  displayName     String
  email           String?
  emailNormalized String?           @unique
  phone           String?
  phoneNormalized String?           @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  accounts        CustomerAccount[]
  addresses       CustomerAddress[]
  orders          Order[]
  notifications   NotificationCapture[]

  @@index([displayName])
}

model CustomerAddress {
  id              String    @id @default(cuid())
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label           String?
  recipientName   String
  line1           String
  line2           String?
  city            String
  region          String
  postalCode      String
  countryCode     String    @default("US")
  normalizedKey   String
  latitude        Decimal?  @db.Decimal(9, 6)
  longitude       Decimal?  @db.Decimal(9, 6)
  geocodedAt      DateTime?
  geocodeProvider String?
  rememberedGreeting String?
  version         Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  packages        Package[]
  orderLines      OrderLine[]

  @@unique([customerId, normalizedKey])
}

model Order {
  id                  String                @id @default(cuid())
  seasonId            String
  season              Season                @relation(fields: [seasonId], references: [id])
  customerId          String
  customer            Customer              @relation(fields: [customerId], references: [id])
  status              OrderStatus           @default(DRAFT)
  orderNumber         Int?
  draftReference      String                @unique
  guestAccessTokenHash String?               @unique
  guestAccessExpiresAt DateTime?
  wireFormatVersion   Int                   @default(1)
  cachedPaymentStatus CachedPaymentStatus   @default(UNPAID)
  subtotalCents       Int                   @default(0)
  donationCents       Int                   @default(0)
  totalCents          Int                   @default(0)
  defaultGreeting     String                @default("")
  confirmationTriggeredAt DateTime?
  finalizedAt         DateTime?
  discardedAt         DateTime?
  version             Int                   @default(1)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  lines               OrderLine[]
  packages            Package[]
  payments            Payment[]
  paymentIntents      StripePaymentIntent[]

  @@unique([seasonId, orderNumber])
  @@index([customerId, createdAt])
  @@index([seasonId, status])
  @@index([status, createdAt])
  @@index([cachedPaymentStatus, createdAt])
}

model OrderLine {
  id                     String           @id @default(cuid())
  orderId                String
  order                  Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId              String
  product                Product          @relation(fields: [productId], references: [id])
  productOptionId        String?
  productOption          ProductOption?   @relation(fields: [productOptionId], references: [id])
  recipientAddressId     String?
  recipientAddress       CustomerAddress? @relation(fields: [recipientAddressId], references: [id])
  recipientSource        RecipientAssignmentSource?
  recipientNameSnapshot  String?
  fulfillmentMethodId    String?
  fulfillmentMethod      FulfillmentMethod? @relation(fields: [fulfillmentMethodId], references: [id])
  fulfillmentFeeCentsSnapshot Int           @default(0)
  greetingSnapshot       String             @default("")
  deliveryDay            String?
  productNameSnapshot    String
  skuSnapshot            String
  unitPriceCentsSnapshot Int
  quantity               Int
  addOns                 OrderLineAddOn[]
  packageLines           PackageLine[]

  @@index([orderId])
  @@index([recipientAddressId])
  @@index([fulfillmentMethodId])
}

model OrderLineAddOn {
  id                     String    @id @default(cuid())
  orderLineId            String
  orderLine              OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  addOnProductId         String
  addOnProduct           Product   @relation(fields: [addOnProductId], references: [id])
  addOnNameSnapshot      String
  unitPriceCentsSnapshot Int
  quantity               Int

  @@index([orderLineId])
}

model FulfillmentMethod {
  id              String    @id @default(cuid())
  seasonId        String
  season          Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  code            String
  displayName     String
  requiresAddress Boolean   @default(true)
  isPickup        Boolean   @default(false)
  isShipping      Boolean   @default(false)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  packages        Package[]
  orderLines      OrderLine[]

  @@unique([seasonId, code])
}

model Package {
  id                  String            @id @default(cuid())
  orderId             String
  order               Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recipientAddressId  String?
  recipientAddress    CustomerAddress?  @relation(fields: [recipientAddressId], references: [id])
  fulfillmentMethodId String
  fulfillmentMethod   FulfillmentMethod @relation(fields: [fulfillmentMethodId], references: [id])
  recipientName       String
  addressSnapshot     Json?
  greetingSnapshot    String
  groupingKey         String
  stage               PackageStage      @default(NEW)
  isActive            Boolean           @default(true)
  version             Int               @default(1)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  lines               PackageLine[]
  audits              PackageAudit[]
  shippingQuotes      ShippingQuote[]
  shipmentBoxes       ShipmentBox[]
  shippingLabels      ShippingLabel[]
  deliveryStop        DeliveryStop?
  pickupLocationId    String?
  pickupLocation      PickupLocation? @relation(fields: [pickupLocationId], references: [id])
  pickupReadyAt       DateTime?
  pickupReadyNotifiedAt DateTime?
  pickupExpiresAt     DateTime?
  pickupExpiredAt     DateTime?
  bulkDeliveryStart   DateTime?
  bulkDeliveryEnd     DateTime?

  @@unique([orderId, groupingKey])
  @@index([isActive, stage, updatedAt])
  @@index([stage, updatedAt])
  @@index([pickupExpiresAt, pickupExpiredAt])
}

model PackageLine {
  id          String    @id @default(cuid())
  packageId   String
  package     Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  orderLineId String
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id])
  quantity    Int

  @@unique([packageId, orderLineId])
}

model PackageAudit {
  id           String        @id @default(cuid())
  packageId    String
  package      Package       @relation(fields: [packageId], references: [id], onDelete: Cascade)
  actorStaffId String?
  action       String
  fromStage    PackageStage?
  toStage      PackageStage?
  metadata     Json?
  occurredAt   DateTime      @default(now())

  @@index([packageId, occurredAt])
}

model PrintBatch {
  id               String         @id @default(cuid())
  runKey           String         @unique
  kind             PrintBatchKind
  createdByStaffId String?
  createdAt        DateTime       @default(now())
  artifacts        PrintArtifact[]

  @@index([kind, createdAt])
}

model PrintArtifact {
  id               String            @id @default(cuid())
  printBatchId     String
  printBatch       PrintBatch        @relation(fields: [printBatchId], references: [id], onDelete: Cascade)
  filingGroup      String
  kind             PrintArtifactKind
  orderId          String?
  sourceArtifactId String?
  payload          Json
  createdAt        DateTime          @default(now())

  @@unique([printBatchId, filingGroup, kind, orderId])
  @@index([filingGroup, kind, createdAt])
  @@index([orderId, createdAt])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  method          PaymentMethod
  status          PaymentStatus @default(POSTED)
  amountCents     Int
  refundedCents   Int           @default(0)
  reference       String?
  postedByStaffId String?
  postedAt        DateTime      @default(now())
  voidedAt        DateTime?
  voidedByStaffId String?
  createdAt       DateTime      @default(now())

  @@index([orderId, status])
  @@unique([method, reference])
}

model StripePaymentIntent {
  id                    String              @id @default(cuid())
  orderId               String
  order                 Order               @relation(fields: [orderId], references: [id])
  stripePaymentIntentId String              @unique
  stripeCheckoutSessionId String?           @unique
  idempotencyKey        String              @unique
  status                PaymentIntentStatus
  amountCents           Int
  currency              String              @default("usd")
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([orderId, status])
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
}

model ShippingQuote {
  id              String    @id @default(cuid())
  packageId       String
  package         Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  provider        String
  serviceCode     String
  serviceName     String
  amountCents     Int
  currency        String    @default("usd")
  providerQuoteId String?
  expiresAt       DateTime
  selectedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([packageId, expiresAt])
}

model ShippingLabel {
  id                    String              @id @default(cuid())
  packageId             String
  package               Package             @relation(fields: [packageId], references: [id], onDelete: Cascade)
  shipmentBoxId         String?
  shipmentBox           ShipmentBox?        @relation(fields: [shipmentBoxId], references: [id])
  provider              String
  serviceCode           String
  providerRateId        String
  providerTransactionId String?             @unique
  trackingNumber        String?
  trackingStatus        String?
  labelUrl              String?
  chargedCents          Int
  purchasedCents        Int
  marginCents           Int
  currency              String              @default("usd")
  status                ShippingLabelStatus @default(PURCHASED)
  failureMessage        String?
  purchasedAt           DateTime?
  voidedAt              DateTime?
  trackingRefreshedAt   DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([packageId, status])
  @@index([trackingNumber])
}

model PickupLocation {
  id           String  @id @default(cuid())
  seasonId     String
  season       Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  name         String
  address      Json
  instructions String?
  isActive     Boolean @default(true)
  packages     Package[]

  @@unique([seasonId, name])
}

model DeliveryRoute {
  id                    String              @id @default(cuid())
  name                  String
  status                DeliveryRouteStatus @default(PLANNED)
  assignedDriverId      String?
  assignedDriver        StaffUser?          @relation("AssignedDriver", fields: [assignedDriverId], references: [id])
  startedAt             DateTime?
  completedAt           DateTime?
  printRevision         Int                 @default(1)
  dayOfNotificationsAt  DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  stops                 DeliveryStop[]
  links                 DriverMagicLink[]
  audits                DriverDeliveryAudit[]

  @@index([status, createdAt])
  @@index([assignedDriverId, status])
}

model DeliveryStop {
  id          String             @id @default(cuid())
  routeId     String
  route       DeliveryRoute      @relation(fields: [routeId], references: [id], onDelete: Cascade)
  packageId   String             @unique
  package     Package            @relation(fields: [packageId], references: [id])
  sequence    Int
  latitude    Decimal            @db.Decimal(9, 6)
  longitude   Decimal            @db.Decimal(9, 6)
  status      DeliveryStopStatus @default(PENDING)
  deliveredAt DateTime?
  createdAt   DateTime           @default(now())

  @@unique([routeId, sequence])
  @@index([routeId, status, sequence])
}

model DriverMagicLink {
  id              String        @id @default(cuid())
  routeId         String
  route           DeliveryRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  tokenHash       String        @unique
  pinHash         String?
  expiresAt       DateTime
  failedAttempts  Int           @default(0)
  lockedUntil     DateTime?
  lastUsedAt      DateTime?
  expiredAt       DateTime?
  createdAt       DateTime      @default(now())
  audits          DriverDeliveryAudit[]

  @@index([routeId, expiresAt])
}

model DriverDeliveryAudit {
  id          String          @id @default(cuid())
  routeId     String
  route       DeliveryRoute   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stopId      String
  linkId      String
  link        DriverMagicLink @relation(fields: [linkId], references: [id])
  deliveredAt DateTime        @default(now())

  @@index([routeId, deliveredAt])
  @@index([linkId, deliveredAt])
}

model NotificationCapture {
  id          String    @id @default(cuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  packageId   String?
  channel     String
  eventKey    String
  destination String
  payload     Json
  sentAt      DateTime  @default(now())

  @@unique([eventKey, channel])
  @@index([customerId, sentAt])
  @@index([packageId, sentAt])
}

model PackageType {
  id             String        @id @default(cuid())
  seasonId       String
  season         Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  name           String
  innerWidthMm   Int
  innerHeightMm  Int
  innerDepthMm   Int
  maxWeightGrams Int?
  isActive       Boolean       @default(true)
  shipmentBoxes  ShipmentBox[]

  @@unique([seasonId, name])
}

model ShipmentBox {
  id            String      @id @default(cuid())
  packageId     String
  package       Package     @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageTypeId String
  packageType   PackageType @relation(fields: [packageTypeId], references: [id])
  sequence      Int
  weightGrams   Int?
  createdAt     DateTime    @default(now())
  shippingLabels ShippingLabel[]

  @@unique([packageId, sequence])
}

model InventoryItem {
  id         String              @id @default(cuid())
  targetKind InventoryTargetKind
  productId  String?             @unique
  product    Product?            @relation("ProductInventory", fields: [productId], references: [id], onDelete: Cascade)
  addOnId    String?             @unique
  addOn      Product?            @relation("AddOnInventory", fields: [addOnId], references: [id], onDelete: Cascade)
  onHand     Int                 @default(0)
  reserved   Int                 @default(0)
  version    Int                 @default(1)
  updatedAt  DateTime            @updatedAt

  @@index([targetKind])
}

model GeocodeCache {
  id               String   @id @default(cuid())
  normalizedKey    String   @unique
  provider         String
  latitude         Decimal? @db.Decimal(9, 6)
  longitude        Decimal? @db.Decimal(9, 6)
  formattedAddress String?
  failureCode      String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([expiresAt])
}

model CronRun {
  id           String    @id @default(cuid())
  jobName      String
  runKey       String    @unique
  status       String
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  claimed      Int       @default(0)
  succeeded    Int       @default(0)
  failed       Int       @default(0)
  errorSummary String?

  @@index([jobName, startedAt])
}

model GuestDraftThrottle {
  key             String   @id
  windowStartedAt DateTime
  attempts        Int
  updatedAt       DateTime @updatedAt
}

model PublicRequestThrottle {
  key             String   @id
  windowStartedAt DateTime
  attempts        Int
  updatedAt       DateTime @updatedAt
}

model Ingredient {
  id        String              @id @default(cuid())
  sku       String              @unique
  name      String
  unit      String
  onHand    Decimal             @default(0) @db.Decimal(12, 3)
  version   Int                 @default(1)
  products  ProductIngredient[]
  batchUses AssemblyBatchUse[]
}

model ProductIngredient {
  productId    String
  ingredientId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity     Decimal    @db.Decimal(12, 3)

  @@id([productId, ingredientId])
}

model AssemblyBatch {
  id          String              @id @default(cuid())
  seasonId    String
  season      Season              @relation(fields: [seasonId], references: [id])
  reference   String
  status      AssemblyBatchStatus @default(PLANNED)
  plannedFor  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  uses        AssemblyBatchUse[]

  @@unique([seasonId, reference])
}

model AssemblyBatchUse {
  assemblyBatchId String
  ingredientId    String
  assemblyBatch   AssemblyBatch @relation(fields: [assemblyBatchId], references: [id], onDelete: Cascade)
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id])
  quantity        Decimal       @db.Decimal(12, 3)

  @@id([assemblyBatchId, ingredientId])
}
