{
  "name": "workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:guard": "prisma validate && prisma migrate status",
    "db:seed": "tsx prisma/seed.ts",
    "env:example": "node scripts/generate-env-example.mjs",
    "smoke:concurrency": "tsx scripts/concurrency-smoke.ts",
    "smoke:p6": "tsx scripts/p6-smoke.ts",
    "smoke:p7": "tsx scripts/p7-smoke.ts",
    "smoke:p8": "tsx scripts/p8-smoke.ts",
    "smoke:p9": "tsx scripts/p9-smoke.ts",
    "smoke:p10": "tsx scripts/p10-smoke.ts",
    "ci": "npm run lint && npm run typecheck && npm test && npm run db:guard"
  },
  "dependencies": {
    "@clerk/nextjs": "7.5.20",
    "@expo-google-fonts/noto-sans-hebrew": "0.4.1",
    "@prisma/client": "6.19.3",
    "@vercel/blob": "^2.6.1",
    "bidi-js": "1.0.3",
    "next": "16.2.10",
    "pdfkit": "0.19.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "22.3.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "20.19.43",
    "@types/pdfkit": "0.17.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prisma": "6.19.3",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
